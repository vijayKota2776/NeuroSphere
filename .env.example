# ============================================================================
# NeuroSphere — Environment Variables
# Copy this file to .env and customise for your deployment.
#
#   cp .env.example .env
#
# All values shown are sensible defaults for local development.
# ============================================================================

# ---------------------------------------------------------------------------
# Global / Shared
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO                          # DEBUG | INFO | WARNING | ERROR
FLASK_ENV=production                    # development | production
NODE_ENV=production                     # development | production

# ---------------------------------------------------------------------------
# API Gateway (Nginx)
# ---------------------------------------------------------------------------
GATEWAY_HOST_PORT=8080                  # Host port mapped to gateway :80
NGINX_QUIET_LOGS=0                      # Set 1 to suppress entrypoint logs

# ---------------------------------------------------------------------------
# Robot Command Service (:5000)
# ---------------------------------------------------------------------------
MAX_ROBOT_VELOCITY=0.05                 # Max end-effector velocity (m/s)
SAFETY_INTERLOCK_ENABLED=true           # Enable hardware safety interlocks
ROBOT_HEARTBEAT_INTERVAL_MS=250         # Heartbeat interval to robot controller
ROBOT_COMMAND_TIMEOUT_MS=5000           # Max time to wait for command ACK
EMERGENCY_STOP_DECEL=2.0               # Emergency stop deceleration (m/s²)

# ---------------------------------------------------------------------------
# Diagnostic Engine Service (:3000)
# ---------------------------------------------------------------------------
MODEL_CONFIDENCE_THRESHOLD=0.85        # Min confidence for positive diagnosis
MAX_CONCURRENT_ANALYSES=4              # Parallel diagnostic pipelines
IMAGING_UPLOAD_MAX_MB=256              # Max upload size for medical images
DICOM_PARSER_STRICT=true              # Strict DICOM tag validation
REPORT_RETENTION_DAYS=90              # Days to retain generated reports

# ---------------------------------------------------------------------------
# Patient Monitor Service (:5001)
# ---------------------------------------------------------------------------
VITALS_ALERT_ENABLED=true              # Enable real-time vitals alerting
HEART_RATE_CRITICAL_LOW=40             # BPM — bradycardia threshold
HEART_RATE_CRITICAL_HIGH=180           # BPM — tachycardia threshold
SPO2_CRITICAL_LOW=88                   # % — hypoxemia threshold
SYSTOLIC_BP_CRITICAL_HIGH=180          # mmHg — hypertensive crisis
DIASTOLIC_BP_CRITICAL_HIGH=120         # mmHg — hypertensive crisis
TEMPERATURE_CRITICAL_HIGH=40.0         # °C — hyperthermia threshold
VITALS_POLLING_INTERVAL_MS=1000        # How often to poll vitals sources
EHR_INTEGRATION_ENABLED=false          # Enable HL7/FHIR EHR integration
EHR_FHIR_BASE_URL=                     # FHIR R4 server base URL

# ---------------------------------------------------------------------------
# Telemetry Ingest Service (:5002)
# ---------------------------------------------------------------------------
INGEST_BATCH_SIZE=100                  # Events per batch write
INGEST_FLUSH_INTERVAL_MS=5000          # Max time before flushing batch
MAX_TELEMETRY_AGE_SECONDS=300          # Reject events older than this
TELEMETRY_STORAGE_BACKEND=memory       # memory | redis | timescaledb
REDIS_URL=                             # Redis connection string (if used)
TIMESCALEDB_URL=                       # TimescaleDB connection string

# ---------------------------------------------------------------------------
# Prometheus / Monitoring
# ---------------------------------------------------------------------------
PROMETHEUS_METRICS_ENABLED=true        # Expose /metrics endpoint
METRICS_PREFIX=neurosphere             # Prefix for all custom metrics

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=*                 # Comma-separated origins, or * for all
API_KEY=                               # Optional API key for gateway auth
JWT_SECRET=                            # Secret for JWT token validation
JWT_EXPIRY_MINUTES=60                  # Token expiry duration
